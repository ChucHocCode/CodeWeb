@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Nhập - Skyblue Airlines</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Times New Roman", Times, serif;
            background: linear-gradient(135deg,#0e5fb6 0%,#2b74c3 50%,#4e95df 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-card {
            background: #fff;
            border-radius: 14px;
            padding: 36px 40px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 24px 60px rgba(14,50,100,.3);
        }

        .auth-brand {
            text-align: center;
            margin-bottom: 28px;
        }
        .auth-brand-icon {
            width: 52px; height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg,#2a66b8,#4e95df);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 10px;
            color: #fff;
        }
        .auth-brand-icon svg { width: 28px; height: 28px; stroke: #fff; }
        .auth-brand h1 { margin: 0; font-size: 26px; font-weight: 800; color: #2a66b8; }
        .auth-brand p  { margin: 4px 0 0; font-size: 13px; color: #607089; }

        .auth-tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
            border: 1px solid #d6dfeb;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 24px;
        }
        .tab-btn {
            border: 0; background: #f5f8fc; color: #607089;
            font-size: 14px; font-weight: 600; padding: 10px;
            cursor: pointer; font-family: inherit; transition: all .2s;
        }
        .tab-btn.active { background: #2a66b8; color: #fff; }

        .auth-error {
            background: #fee2e2; border: 1px solid #fca5a5; color: #b91c1c;
            border-radius: 7px; padding: 10px 12px; margin-bottom: 16px;
            font-size: 13px; display: none;
        }
        .auth-success {
            background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d;
            border-radius: 7px; padding: 10px 12px; margin-bottom: 16px;
            font-size: 13px; display: none;
        }

        .auth-form { display: flex; flex-direction: column; gap: 12px; }
        .auth-input {
            height: 44px;
            border: 1px solid #cfdcee; border-radius: 8px;
            padding: 0 14px; font-size: 14px; background: #f8fbff;
            font-family: inherit; color: #213047; transition: border-color .2s;
        }
        .auth-input:focus { outline: none; border-color: #2a66b8; background: #fff; }
        .auth-input:disabled { opacity: .6; cursor: not-allowed; }

        .auth-button {
            height: 44px; border: 0; border-radius: 8px;
            background: #2a66b8; color: #fff;
            font-size: 15px; font-weight: 700;
            cursor: pointer; font-family: inherit; transition: background .2s;
        }
        .auth-button:hover:not(:disabled) { background: #1f4f95; }
        .auth-button:disabled { opacity: .65; cursor: not-allowed; }

        .auth-link-row {
            text-align: center; margin-top: 12px; font-size: 13px; color: #607089;
        }
        .auth-link {
            background: none; border: none; color: #2a66b8;
            font-weight: 700; cursor: pointer; font-family: inherit; font-size: 13px;
            padding: 0;
        }
        .auth-link:hover { text-decoration: underline; }

        .form-check-row {
            display: flex; align-items: center; gap: 8px;
            font-size: 13px; color: #607089;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-brand">
            <div class="auth-brand-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                    <path d="M17.8 19.2L16 11l3.5-6.1A2 2 0 0 0 15.4 2H4c-.9 0-1.8.5-2.3 1.3L.5 9c-.7 1.2-.7 2.8 0 4l3.2 5.7c.5.8 1.4 1.3 2.3 1.3h11.4a2 2 0 0 0 1.8-1.1m-4-4l2-4m0 0l2-4m-11 11l-5 5m0 5v-5m0 5h5"/>
                </svg>
            </div>
            <h1>Skyblue</h1>
            <p>Dịch vụ vé máy bay nhanh chóng và tiện lợi</p>
        </div>

        <div class="auth-tabs">
            <button class="tab-btn active" id="tabLogin" onclick="switchTab('login')">Đăng nhập</button>
            <button class="tab-btn" id="tabRegister" onclick="switchTab('register')">Đăng ký</button>
        </div>

        <!-- ĐĂNG NHẬP -->
        <div id="panelLogin">
            <div class="auth-error" id="loginError"></div>
            <div class="auth-form">
                <input type="text" id="loginUsername" class="auth-input" placeholder="Email hoặc tên đăng nhập" />
                <input type="password" id="loginPassword" class="auth-input" placeholder="Mật khẩu" />
                <div class="form-check-row">
                    <input type="checkbox" id="rememberMe" />
                    <label for="rememberMe">Ghi nhớ đăng nhập</label>
                </div>
                <button class="auth-button" id="loginBtn" onclick="doLogin()">ĐĂNG NHẬP</button>
            </div>
            <div class="auth-link-row">
                <button class="auth-link" onclick="switchTab('register')">Chưa có tài khoản? Đăng ký ngay</button>
            </div>
        </div>

        <!-- ĐĂNG KÝ -->
        <div id="panelRegister" style="display:none">
            <div class="auth-error" id="registerError"></div>
            <div class="auth-success" id="registerSuccess"></div>
            <div class="auth-form">
                <input type="text" id="regName" class="auth-input" placeholder="Họ và tên" />
                <input type="text" id="regUsername" class="auth-input" placeholder="Email hoặc tên đăng nhập" />
                <input type="password" id="regPassword" class="auth-input" placeholder="Mật khẩu (tối thiểu 3 ký tự)" />
                <input type="password" id="regPasswordConfirm" class="auth-input" placeholder="Xác nhận mật khẩu" />
                <button class="auth-button" id="registerBtn" onclick="doRegister()">TẠO TÀI KHOẢN</button>
            </div>
            <div class="auth-link-row">
                <button class="auth-link" onclick="switchTab('login')">Đã có tài khoản? Đăng nhập</button>
            </div>
        </div>
    </div>

    <script>
        function switchTab(tab) {
            var isLogin = tab === 'login';
            document.getElementById('panelLogin').style.display    = isLogin ? 'block' : 'none';
            document.getElementById('panelRegister').style.display = isLogin ? 'none'  : 'block';
            document.getElementById('tabLogin').classList.toggle('active', isLogin);
            document.getElementById('tabRegister').classList.toggle('active', !isLogin);
        }

        function showMsg(id, msg, type) {
            var el = document.getElementById(id);
            el.textContent = msg;
            el.style.display = 'block';
        }
        function hideAll() {
            ['loginError','registerError','registerSuccess'].forEach(function(id) {
                document.getElementById(id).style.display = 'none';
            });
        }

        function doLogin() {
            var username = document.getElementById('loginUsername').value.trim();
            var password = document.getElementById('loginPassword').value;
            var btn = document.getElementById('loginBtn');
            hideAll();
            if (!username || !password) { showMsg('loginError','Vui lòng điền đầy đủ thông tin.'); return; }
            btn.disabled = true; btn.textContent = 'Đang đăng nhập...';
            fetch('/Account/Login', {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({username, password, rememberMe: document.getElementById('rememberMe').checked})
            }).then(r => r.json()).then(function(data) {
                if (data.success) { window.location.href = '/Home/Index'; }
                else { showMsg('loginError', data.message || 'Đăng nhập thất bại.'); btn.disabled = false; btn.textContent = 'ĐĂNG NHẬP'; }
            }).catch(function() {
                showMsg('loginError','Lỗi kết nối. Vui lòng thử lại.'); btn.disabled = false; btn.textContent = 'ĐĂNG NHẬP';
            });
        }

        function doRegister() {
            var name = document.getElementById('regName').value.trim();
            var username = document.getElementById('regUsername').value.trim();
            var password = document.getElementById('regPassword').value;
            var confirm  = document.getElementById('regPasswordConfirm').value;
            var btn = document.getElementById('registerBtn');
            hideAll();
            if (!name || !username || !password) { showMsg('registerError','Vui lòng điền đầy đủ thông tin.'); return; }
            if (password !== confirm) { showMsg('registerError','Mật khẩu xác nhận không khớp.'); return; }
            if (password.length < 3)  { showMsg('registerError','Mật khẩu phải có ít nhất 3 ký tự.'); return; }
            btn.disabled = true; btn.textContent = 'Đang tạo tài khoản...';
            fetch('/Account/Register', {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({id:'u_'+Date.now(), name, email:username, password, createdAt:new Date().toISOString(), updatedAt:new Date().toISOString()})
            }).then(r => r.json()).then(function(data) {
                if (data.success) {
                    document.getElementById('registerSuccess').textContent = data.message + ' Chuyển sang đăng nhập...';
                    document.getElementById('registerSuccess').style.display = 'block';
                    setTimeout(function() { switchTab('login'); document.getElementById('loginUsername').value = username; }, 1500);
                } else { showMsg('registerError', data.message || 'Đăng ký thất bại.'); }
                btn.disabled = false; btn.textContent = 'TẠO TÀI KHOẢN';
            }).catch(function() {
                showMsg('registerError','Lỗi kết nối.'); btn.disabled = false; btn.textContent = 'TẠO TÀI KHOẢN';
            });
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                var isLogin = document.getElementById('panelLogin').style.display !== 'none';
                isLogin ? doLogin() : doRegister();
            }
        });
    </script>
</body>
</html>
