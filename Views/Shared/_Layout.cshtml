<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Skyblue Airlines</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        :root {
            --sky: #2a66b8;
            --sky-dark: #1f4f95;
            --page-bg: #f3f7fc;
            --text: #213047;
            --muted: #607089;
            --line: #d9e4f2;
        }
        body {
            margin: 0;
            font-family: "Times New Roman", Times, serif;
            color: var(--text);
            background: linear-gradient(180deg,#f7faff 0%,var(--page-bg) 42%,#eef4fb 100%);
            min-height: 100vh;
        }

        /* ── HEADER ── */
        .site-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: linear-gradient(180deg,#2f71c4 0%,#2a66b8 100%);
            color: #fff;
            box-shadow: 0 6px 18px rgba(21,54,101,.18);
        }
        .header-top, .header-nav-wrap {
            max-width: 1320px;
            margin: 0 auto;
            padding: 0 16px;
        }
        .header-top {
            min-height: 72px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
        }
        .brand-mark {
            width: 42px; height: 42px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,.8);
            display: flex; align-items: center; justify-content: center;
            color: #fff; flex-shrink: 0;
        }
        .brand-mark svg { width: 22px; height: 22px; stroke: currentColor; }
        .brand-text h1 { margin: 0; font-size: 30px; font-weight: 800; color: #fff; line-height: 1; }
        .brand-text p  { margin: 2px 0 0; font-size: 12px; color: #e8f1ff; }

        .header-tools { display: flex; align-items: center; gap: 10px; }
        .locale-chip {
            border: 1px solid rgba(230,240,255,.8); border-radius: 4px;
            background: transparent; color: #f2f8ff;
            height: 32px; padding: 0 10px; font-size: 12px; font-weight: 700;
            display: flex; align-items: center; gap: 6px; cursor: pointer;
            font-family: inherit;
        }
        .user-menu { position: relative; }
        .icon-user {
            min-width: 32px; height: 32px; border-radius: 999px;
            border: 1px solid rgba(230,240,255,.8);
            background: transparent; color: #fff; cursor: pointer;
            display: inline-flex; align-items: center; gap: 8px;
            padding: 0 10px 0 0; font-family: inherit;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 999px;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 800;
            background: rgba(255,255,255,.18); flex-shrink: 0;
        }
        .user-label {
            max-width: 130px; overflow: hidden; text-overflow: ellipsis;
            white-space: nowrap; font-size: 12px; font-weight: 700; color: #eef5ff;
        }
        .dropdown-menu {
            position: absolute; right: 0; top: calc(100% + 8px);
            min-width: 180px; background: #fff; color: #0f172a;
            border: 1px solid #d5deea; border-radius: 8px;
            box-shadow: 0 16px 40px rgba(15,35,74,.2); overflow: hidden;
            display: none; z-index: 200;
        }
        .dropdown-menu.open { display: block; }
        .dropdown-menu a, .dropdown-menu button {
            display: block; width: 100%; border: 0; background: #fff;
            color: #111827; text-align: left; padding: 10px 12px;
            cursor: pointer; font-size: 13px; text-decoration: none;
            font-family: inherit;
        }
        .dropdown-menu a:hover, .dropdown-menu button:hover { background: #edf4ff; }

        /* ── NAV ── */
        .header-nav-wrap { border-top: 1px solid rgba(237,245,255,.2); }
        .header-nav { display: flex; align-items: center; overflow-x: hidden; }
        .nav-link {
            flex: 1 1 0; border: 0; border-bottom: 3px solid transparent;
            background: transparent; color: #fff; white-space: nowrap;
            text-align: center; padding: 14px 10px 12px;
            font-size: 15px; font-weight: 600; cursor: pointer;
            transition: all .2s; text-decoration: none;
            display: block; font-family: inherit;
        }
        .nav-link:hover { background: rgba(255,255,255,.12); color: #fff; }
        .nav-link.active { border-bottom-color: #fff; font-weight: 700; }
        .nav-link.disabled { opacity: .5; cursor: not-allowed; pointer-events: none; }

        /* ── MAIN ── */
        .main-content {
            max-width: 1320px;
            margin: 0 auto;
            padding: 16px 16px 32px;
        }

        @@media (max-width: 900px) {
            .brand-text p { display: none; }
            .user-label { display: none; }
            .icon-user { padding-right: 0; }
            .nav-link { font-size: 13px; padding: 12px 8px 10px; flex: 0 0 auto; }
            .header-nav { overflow-x: auto; }
        }
    </style>
</head>
<body>

@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var act  = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavCls(string c, string a = "") =>
        (ctrl == c && (a == "" || act == a)) ? "nav-link active" : "nav-link";

    var displayName = User.Identity?.Name ?? "Khách";
    var initials = string.Concat(
        displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                   .Take(2).Select(p => char.ToUpper(p[0])));
    if (string.IsNullOrEmpty(initials)) initials = "U";
}

<header class="site-header">
    <div class="header-top">
        <a href="/Home/Index" class="brand">
            <div class="brand-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2">
                    <path d="M17.8 19.2L16 11l3.5-6.1A2 2 0 0 0 15.4 2H4c-.9 0-1.8.5-2.3 1.3L.5 9c-.7 1.2-.7 2.8 0 4l3.2 5.7c.5.8 1.4 1.3 2.3 1.3h11.4a2 2 0 0 0 1.8-1.1m-4-4l2-4m0 0l2-4m-11 11l-5 5m0 5v-5m0 5h5"/>
                </svg>
            </div>
            <div class="brand-text">
                <h1>Skyblue</h1>
                <p>Dịch vụ vé máy bay nhanh chóng và tiện lợi</p>
            </div>
        </a>

        <div class="header-tools">
            <button class="locale-chip">
                <span style="display:inline-flex;align-items:center;justify-content:center;min-width:18px;height:13px;background:#ce232a;border-radius:2px;font-size:9px;">VN</span>
                <span>VND | VI</span>
            </button>

            <div class="user-menu">
                <button class="icon-user" onclick="toggleUserMenu()">
                    <span class="user-avatar">@initials</span>
                    <span class="user-label">@displayName</span>
                </button>
                <div class="dropdown-menu" id="userDropdown">
                    <a href="#">@displayName</a>
                    <a href="/Account/Logout">Đăng xuất</a>
                </div>
            </div>
        </div>
    </div>

    <div class="header-nav-wrap">
        <nav class="header-nav">
            <a href="/Home/Index"              class="@NavCls("Home")">Tìm kiếm chuyến bay</a>
            <a href="/Home/Booking"            class="@NavCls("Home","Booking")">Đặt vé &amp; giữ chỗ</a>
            <a href="/Payment/Index"           class="@NavCls("Payment")">Thanh toán</a>
            <a href="/TicketStatus/Index"      class="@NavCls("TicketStatus")">Trạng thái vé</a>
            <a href="/RefundExchange/Index"    class="@NavCls("RefundExchange")">Hoàn vé/Đổi vé</a>
            <a href="/Contact/Index"           class="@NavCls("Contact")">Liên hệ</a>
        </nav>
    </div>
</header>

<main class="main-content">
    @RenderBody()
</main>

<script>
    function toggleUserMenu() {
        document.getElementById('userDropdown').classList.toggle('open');
    }
    document.addEventListener('click', function(e) {
        var menu = document.querySelector('.user-menu');
        if (menu && !menu.contains(e.target)) {
            document.getElementById('userDropdown').classList.remove('open');
        }
    });
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
