@model WNCAirline.Controllers.PaymentSuccessViewModel

@{
    ViewData["Title"] = "Thanh Toán Thành Công";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/payment.css" asp-append-version="true" />
}

<section class="card">
    <h2>Thanh Toán Thành Công</h2>
    <p>Giao dịch QR của bạn đã được ghi nhận.</p>
    @if (Model.IsPayoutToUser)
    {
        <p>Đã gửi thông tin hoàn tiền về email của người dùng.</p>
    }

    <table>
        <tbody>
            <tr>
                <th>PNR</th>
                <td>@Model.PNR</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <th>Hành Trình</th>
                <td>@Model.Route</td>
            </tr>
            <tr>
                <th>Ngày Bay</th>
                <td>@Model.FlightDate</td>
            </tr>
            <tr>
                <th>@(Model.IsExchangePayment ? "Số Tiền Đã Thanh Toán Thêm" : "Tổng Tiền")</th>
                <td>@Model.Total</td>
            </tr>
            <tr>
                <th>Thời Gian Xác Nhận</th>
                <td>@Model.PaidAt</td>
            </tr>
        </tbody>
    </table>

    <div class="actions">
        <a class="ghost" href="@Url.Action("Index", "TicketStatus")">Về trạng thái vé</a>
        <a class="btn-link" href="@Url.Action("Index", "Home")">Về trang chủ</a>
    </div>
</section>
