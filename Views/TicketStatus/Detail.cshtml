@model WNCAirline.Controllers.TicketStatusDetailViewModel

@{
    ViewData["Title"] = "Chi Tiết Vé " + Model.BookingCode;

    string badgeCss = Model.StatusKey switch {
        "paid"              => "ok",
        "held"              => "warn",
        "pending-refund"    => "refund",
        "pending-exchange"  => "exchange",
        "refunded"          => "refund",
        "exchanged"         => "exchange",
        _                   => "muted"
    };
}

<style>
    *, *::before, *::after { box-sizing: border-box; }
    .detail-page { min-height: calc(100vh - 110px); padding: 16px 0 40px; }
    .detail-container { max-width: 1000px; margin: 0 auto; padding: 0 16px; }

    .detail-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; gap: 12px; }
    .detail-header h1 { margin: 0; font-size: 26px; font-weight: 800; color: #1a2a42; }
    .back-link {
        border: 1px solid #d6dfeb; border-radius: 8px; background: #fff;
        color: #445064; font-weight: 700; font-size: 13px; padding: 0 16px; height: 36px;
        display: inline-flex; align-items: center; text-decoration: none; gap: 6px;
    }
    .back-link:hover { background: #f5f8ff; color: #2a66b8; }

    .detail-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    .detail-card {
        background: #fff; border: 1px solid #d6e2f1; border-radius: 10px; padding: 18px;
    }
    .detail-card h2 { margin: 0 0 14px; font-size: 17px; font-weight: 800; color: #1a2a42; }

    .detail-row {
        display: flex; justify-content: space-between; align-items: flex-start;
        padding: 9px 0; border-bottom: 1px solid #edf2f8; font-size: 13px; gap: 12px;
    }
    .detail-row:last-child { border-bottom: 0; }
    .detail-row .lbl { color: #64748b; flex-shrink: 0; }
    .detail-row .val { font-weight: 700; color: #1f2937; text-align: right; }
    .detail-row .val.blue { color: #2a66b8; font-size: 15px; }

    .tx-status { padding: 4px 12px; border-radius: 999px; font-size: 13px; font-weight: 700; display: inline-block; }
    .tx-status.ok       { background: #e8f6ee; color: #0f7a3e; }
    .tx-status.warn     { background: #fff6d8; color: #8c6700; }
    .tx-status.muted    { background: #edf1f7; color: #627083; }
    .tx-status.refund   { background: #fff1f2; color: #be123c; }
    .tx-status.exchange { background: #fef9c3; color: #a16207; }

    .status-note {
        margin-top: 14px; border: 1px solid #d6e2f1; border-radius: 8px;
        background: #f8fbff; padding: 10px 12px; font-size: 13px; color: #41506a;
    }

    .detail-actions { margin-top: 18px; display: flex; flex-direction: column; gap: 8px; }
    .btn-action-primary {
        height: 42px; border-radius: 8px; border: 0; background: #2a66b8;
        color: #fff; font-weight: 700; font-size: 14px; cursor: pointer;
        font-family: inherit; text-decoration: none;
        display: flex; align-items: center; justify-content: center;
    }
    .btn-action-primary:hover { background: #1f4f95; }
    .btn-action-secondary {
        height: 42px; border-radius: 8px; border: 1px solid #d6dfeb;
        background: #fff; color: #445064; font-weight: 700; font-size: 14px;
        cursor: pointer; font-family: inherit; text-decoration: none;
        display: flex; align-items: center; justify-content: center;
    }
    .btn-action-secondary:hover { background: #f5f8ff; color: #2a66b8; }
    .btn-action-danger {
        height: 42px; border-radius: 8px; border: 1px solid #fca5a5;
        background: #fff; color: #b91c1c; font-weight: 700; font-size: 14px;
        cursor: pointer; font-family: inherit; text-decoration: none;
        display: flex; align-items: center; justify-content: center;
    }
    .btn-action-danger:hover { background: #fff1f2; }

    @@media (max-width: 800px) {
        .detail-layout { grid-template-columns: 1fr; }
        .detail-header { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="detail-page">
<div class="detail-container">

    <div class="detail-header">
        <h1>Chi tiết vé <span style="color:#2a66b8;">@Model.BookingCode</span></h1>
        <a href="@Url.Action("Index","TicketStatus")" class="back-link">← Quay lại danh sách</a>
    </div>

    <div class="detail-layout">

        <div class="detail-card">
            <h2>Thông tin đặt chỗ</h2>

            <div class="detail-row">
                <span class="lbl">Mã đặt chỗ (PNR)</span>
                <span class="val" style="color:#2a66b8;letter-spacing:.05em;">@Model.BookingCode</span>
            </div>
            <div class="detail-row">
                <span class="lbl">Hành khách / Liên hệ</span>
                <span class="val">@Model.PassengerName</span>
            </div>
            <div class="detail-row">
                <span class="lbl">Hành trình</span>
                <span class="val">@Model.Route</span>
            </div>
            <div class="detail-row">
                <span class="lbl">Ngày bay</span>
                <span class="val">@Model.FlightDate</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Fare))
            {
                <div class="detail-row">
                    <span class="lbl">Giá vé cơ bản</span>
                    <span class="val">@Model.Fare</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Tax))
            {
                <div class="detail-row">
                    <span class="lbl">Thuế &amp; phí sân bay</span>
                    <span class="val">@Model.Tax</span>
                </div>
            }
            <div class="detail-row">
                <span class="lbl">Tổng thanh toán</span>
                <span class="val blue">@Model.Total</span>
            </div>
        </div>

        <div class="detail-card">
            <h2>Trạng thái &amp; thao tác</h2>

            <div class="detail-row">
                <span class="lbl">Trạng thái</span>
                <span class="val"><span class="tx-status @badgeCss">@Model.StatusLabel</span></span>
            </div>
            <div class="detail-row">
                <span class="lbl">Sự kiện gần nhất</span>
                <span class="val">@Model.LastEvent</span>
            </div>
            <div class="detail-row">
                <span class="lbl">Ghi chú</span>
                <span class="val" style="color:#64748b;font-weight:400;">@Model.Reason</span>
            </div>

            @{
                string noteText = Model.StatusKey switch {
                    "paid"             => "Vé đã thanh toán thành công. Bạn có thể yêu cầu hoàn vé hoặc đổi sang chuyến bay khác.",
                    "held"             => "Vé đang được giữ chỗ, chưa thanh toán. Vui lòng thanh toán trước hạn để giữ chỗ.",
                    "refunded"         => "Vé đã được hoàn thành công. Không thể thực hiện thêm thao tác hoàn/đổi.",
                    "exchanged"        => "Vé đã được đổi thành công. Bạn vẫn có thể yêu cầu hoàn vé hoặc đổi tiếp.",
                    "pending-refund"   => "Yêu cầu hoàn vé đang xử lý. Vui lòng hoàn tất QR hoàn tiền.",
                    "pending-exchange" => "Yêu cầu đổi vé đang xử lý. Vui lòng hoàn tất thanh toán chênh lệch.",
                    _                  => string.Empty
                };
            }
            @if (!string.IsNullOrWhiteSpace(noteText))
            {
                <div class="status-note">@noteText</div>
            }

            <div class="detail-actions">
                @if (Model.CanGoPayment)
                {
                    if (Model.StatusKey == "held")
                    {
                        <a href="@Url.Action("FromTicket","Payment", new { code = Model.BookingCode })" class="btn-action-primary">
                            Thanh toán ngay
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("FromTicket","Payment", new { code = Model.BookingCode })" class="btn-action-primary">
                            Tiếp tục xử lý thanh toán
                        </a>
                    }
                }

                @if (Model.CanRefundExchange)
                {
                    <a href="@Url.Action("Index","RefundExchange", new { code = Model.BookingCode })" class="btn-action-danger">
                        Hoàn vé / Đổi vé
                    </a>
                }

                <a href="@Url.Action("Index","TicketStatus")" class="btn-action-secondary">
                    Quay lại danh sách
                </a>
            </div>
        </div>

    </div>
</div>
</div>
